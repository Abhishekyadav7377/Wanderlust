<% layout("layouts/boilerplate") %>
<div class="row mt-4">
    <div class="col-8 offset-2">
        <br><br>
        <h3>Create a New Listing</h3>
        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data" id="listingForm">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input 
                    name="listing[title]" 
                    placeholder="Add a catchy title" 
                    type="text" 
                    class="form-control"
                    required
                />
                <div class="valid-feedback">Title looks good!</div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label> 
                <textarea
                    name="listing[description]" 
                    class="form-control" 
                    required>
                </textarea>
                <div class="invalid-feedback">Please enter a short description</div>
            </div>

            <!-- ✅ CATEGORY DROPDOWN ADD KIYA -->
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select 
                    name="listing[category]"
                    id="category"
                    class="form-control"
                    required
                >
                    <option value="" disabled selected>Select a category</option>
                    <option value="trending">🔥 Trending</option>
                    <option value="rooms">🛏️ Rooms</option>
                    <option value="iconic-cities">🏙️ Iconic Cities</option>
                    <option value="mountains">⛰️ Mountains</option>
                    <option value="castles">🏰 Castles</option>
                    <option value="camping">⛺ Camping</option>
                    <option value="farms">🐄 Farms</option>
                    <option value="arctic">❄️ Arctic</option>
                </select>
                <div class="invalid-feedback">Please select a category</div>
            </div>
            
            <!-- ✅ Multiple Images Upload -->
            <div class="mb-3">
                <label for="images" class="form-label">Upload Listing Images (Max 4)</label>
                <input 
                    name="listing[images]"
                    type="file" 
                    class="form-control"
                    multiple
                    accept="image/*"
                    required
                />
                <small class="text-muted d-block mt-2">You can upload up to 4 images for different angles</small>
                <div class="invalid-feedback">Please upload at least one image</div>
            </div>

            <!-- ✅ LOCATION SEARCH SECTION -->
            <div class="mb-3">
                <label for="locationSearch" class="form-label">📍 Search Location</label>
                <div class="input-group">
                    <input 
                        type="text" 
                        id="locationSearch" 
                        class="form-control" 
                        placeholder="e.g., Delhi, Mumbai, Goa, Bangalore"
                        required
                    />
                    <button type="button" class="btn btn-outline-secondary" onclick="searchLocation()">Search</button>
                </div>
                <small class="text-muted d-block mt-2">Search location aur automatically coordinates fill ho jayenge</small>
                <div id="searchResults" style="display:none; margin-top: 10px;"></div>
            </div>

            
            <input type="hidden" name="listing[latitude]" id="latitude" value="28.6139" required />
            <input type="hidden" name="listing[longitude]" id="longitude" value="77.2170" required />
            
            <div class="mb-3">
                <label class="form-label">🗺️ Map Preview</label>
                <div id="mapNew" style="height: 300px; border: 1px solid #ddd; border-radius: 5px;"></div>
                <small class="text-muted d-block mt-2">Selected location: <span id="selectedLocation">Delhi, India</span></small>
            </div>
            
            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input
                        name="listing[price]" 
                        placeholder="1200" 
                        type="number"
                        class="form-control"
                        required
                    />
                    <div class="invalid-feedback">Price should be valid</div>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input 
                        name="listing[country]" 
                        placeholder="India" 
                        type="text" 
                        class="form-control" 
                        required
                    />
                    <div class="invalid-feedback">Country name should be valid</div>
                </div>
            </div>        
            
            <div class="mb-3">
                <label for="location" class="form-label">Location (Full Address)</label>
                <input 
                    name="listing[location]"
                    id="location"
                    placeholder="e.g., Sector 5, New Delhi" 
                    type="text" 
                    class="form-control"
                    required
                />
                <div class="invalid-feedback">Location should be valid</div>
            </div>
            
            <button class="btn btn-dark add-btn mb-3">Add Listing</button>
        </form>
    </div>
</div>

<script>

    const mapToken = "<%= process.env.MAP_TOKEN %>";
    mapboxgl.accessToken = mapToken;

    // ✅ Mapbox Map initialize
    const mapNew = new mapboxgl.Map({
        container: "mapNew",
        style: "mapbox://styles/mapbox/streets-v12",
        center: [77.2170, 28.6139],
        zoom: 10
    });

    mapNew.addControl(new mapboxgl.NavigationControl());

    let markerNew = new mapboxgl.Marker({ color: "red" })
        .setLngLat([77.2170, 28.6139])
        .addTo(mapNew);

    // ✅ Location Search using Mapbox Geocoding API
    async function searchLocation() {
        const searchInput = document.getElementById('locationSearch').value;
        
        if (!searchInput.trim()) {
            alert('Please enter a location name!');
            return;
        }

        try {
            const response = await fetch(
                `https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(searchInput)}.json?access_token=${mapToken}&limit=1`
            );
            const data = await response.json();

            if (!data.features || data.features.length === 0) {
                alert('Location not found! Try a different name.');
                return;
            }

            const result = data.features[0];
            const [lng, lat] = result.center;  // Mapbox returns [lng, lat]

            document.getElementById('latitude').value = lat;
            document.getElementById('longitude').value = lng;
            document.getElementById('location').value = result.place_name;
            document.getElementById('selectedLocation').textContent = result.place_name;

            // Move map and marker
            mapNew.flyTo({ center: [lng, lat], zoom: 12 });
            markerNew.setLngLat([lng, lat]);

        } catch (error) {
            console.error('Search error:', error);
            alert('Search error occurred!');
        }
    }

    document.getElementById('locationSearch').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchLocation();
        }
    });
</script>